{
  "name": "vscode-smart-path-copy",
  "displayName": "Smart Path Copy",
  "description": "Copy a command based on its path",
  "version": "0.0.8",
  "publisher": "santi-h",
  "repository": {
    "type": "git",
    "url": "https://github.com/santi-h/vscode-smart-path-copy.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartPathCopy.run",
        "title": "Smart Path Copy"
      }
    ],
    "configuration": {
      "title": "Smart Path Copy",
      "properties": {
        "smartPathCopy.pathFormat": {
          "type": "string",
          "enum": ["Windows", "POSIX", "Auto"],
          "default": "Auto",
          "description": "Determines the path format to use when generating commands. 'Windows' for backslashes, 'POSIX' for forward slashes, 'Auto' to use the system default."
        },
        "smartPathCopy.rules": {
          "type": "array",
          "default": [
            {
              "pattern": "_spec\\.rb$",
              "command": "rspec $ruby_filepath:$line_number"
            },
            {
              "pattern": "db/migrate/(\\d{14})_\\w+\\.rb$",
              "command": "rake db:migrate:down VERSION=$1"
            },
            {
              "pattern": "\\btests/.*/(\\w+\\.py)$",
              "command": "pytest -k $1"
            },
            {
              "pattern": "",
              "command": "$rel_filepath"
            }
          ],
          "description": "List of path-matching rules. Each rule has a regex pattern and the command to generate when the path matches. Rules checked in order.",
          "items": {
            "type": "object",
            "required": ["pattern", "command"],
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regular expression to match against the file path."
              },
              "command": {
                "type": "string",
                "description": "Command template to produce when the pattern matches."
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.86.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.9"
  }
}
